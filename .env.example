# UrheiluseuraPro – ympäristömuuttujat

# HTTP-pyyntöjen viive sekunteina (kohtuullinen kuormitus lähteille)
URHEILUSEURAPRO_REQUEST_DELAY=1.0

# HTTP-pyyntöjen aikakatkaisu sekunteina
URHEILUSEURAPRO_REQUEST_TIMEOUT=30.0

# HTTP-pyyntöjen uudelleenyritykset (epäonnistuneet pyynnöt)
URHEILUSEURAPRO_REQUEST_RETRIES=3

# Uudelleenyrityksen backoff kerroin (sekuntia × yritysnumero)
URHEILUSEURAPRO_REQUEST_RETRY_BACKOFF_SECONDS=0.5

# User-Agent -otsikko
URHEILUSEURAPRO_USER_AGENT=UrheiluseuraPro/0.1 (+https://github.com/example/urheiluseurapro)

# Lokitaso: DEBUG, INFO, WARNING, ERROR
URHEILUSEURAPRO_LOG_LEVEL=INFO

# Oletustulostekansio (suhteellinen projektin juureen)
URHEILUSEURAPRO_OUTPUT_DIR=output
